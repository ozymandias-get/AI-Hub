{
  "name": "ai-hub",
  "version": "1.0.0",
  "description": "AI Hub Application",
  "author": "AI Hub <aihub@example.com>",
  "desktopName": "AI Hub",
  "license": "MIT",
  "main": "dist/main/main.js",
  "scripts": {
    "build:main": "tsup --config tsup.config.ts",
    "build:renderer": "vite build --config vite.config.renderer.ts",
    "clean": "node -e \"require('fs').rmSync('dist', { recursive: true, force: true })\"",
    "build": "npm run clean && concurrently -n main,renderer \"npm run build:main\" \"npm run build:renderer\"",
    "start": "npm run build && electron .",
    "dev": "npm run build && electron .",
    "dist": "npm run build && electron-builder",
    "dist:installer": "npm run build && electron-builder --config electron-builder.yml --win nsis",
    "dist:linux": "npm run build && electron-builder --config electron-builder.yml --linux",
    "typecheck": "tsc --noEmit -p tsconfig.main.json && tsc --noEmit -p tsconfig.preload.json && tsc --noEmit -p tsconfig.renderer.json"
  },
  "devDependencies": {
    "concurrently": "^10.0.3",
    "electron": "^43.0.0",
    "electron-builder": "^26.0.0",
    "sharp": "^0.35.3",
    "tsup": "^8.5.0",
    "typescript": "^7.0.0",
    "vite": "^8.0.0"
  }
}
